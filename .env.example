# Copy to .env and fill in. Never commit .env.

# ── Broker ───────────────────────────────────────────────────────────
BROKER_MODE=paper                    # paper | live
ALPACA_API_KEY=
ALPACA_API_SECRET=
# Alpaca endpoints are derived from BROKER_MODE; override only if needed.
# ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ── LLM ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_DEFAULT=claude-sonnet-4-5
ANTHROPIC_MODEL_REFLECTION=claude-opus-4-5
MAX_AGENT_TOKENS_PER_DAY=2000000

# ── Risk ─────────────────────────────────────────────────────────────
RISK_PER_TRADE_PCT=0.01
MAX_POSITION_PCT=0.05
MAX_CONCURRENT_POSITIONS=10
DAILY_LOSS_LIMIT_PCT=0.02
MAX_DRAWDOWN_PCT=0.08

# ── Database / cache ─────────────────────────────────────────────────
POSTGRES_URL=postgresql+psycopg://bot:bot@localhost:5432/bot
REDIS_URL=redis://localhost:6379/0

# ── Runtime ──────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENV=dev                              # dev | prod
