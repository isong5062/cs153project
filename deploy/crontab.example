# Paper-trading cron. Install on the VM as root:
#   crontab /root/trading-bot/deploy/crontab.example
#   crontab -l      # verify
#
# VM clock stays UTC; CRON_TZ re-interprets these times in New York so the
# jobs line up with market close regardless of DST.

SHELL=/bin/bash
PATH=/root/.local/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
CRON_TZ=America/New_York
MAILTO=""

# 17:00 ET Mon-Fri — reconcile DB vs Alpaca. Non-zero exit = drift detected.
0 17 * * 1-5 /root/trading-bot/deploy/reconcile-cron.sh

# 17:15 ET Friday — weekly report.
15 17 * * 5 /root/trading-bot/deploy/paper-report-cron.sh
