# Copy to backend/.env and fill in. Never commit the real .env.

# --- Database ---
# Leave empty to use local SQLite (zero-config dev).
# For Postgres (docker-compose sets this automatically):
#   DATABASE_URL=postgresql+psycopg://trader:trader@localhost:5432/regime_trader
DATABASE_URL=

# --- App ---
APP_ENV=local
CORS_ORIGINS=http://localhost:3000

# --- Alpaca (PAPER ONLY in v1) --- used from Phase 1/5
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true

# --- Anthropic (self-learning #4) --- used from Phase 8
ANTHROPIC_API_KEY=

# --- Alerts (optional) --- POST critical events (circuit breakers, errors) to a webhook.
# Leave empty to log-only. Works with Slack/Discord incoming webhooks.
ALERT_WEBHOOK_URL=
